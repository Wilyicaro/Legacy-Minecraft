{
  "elements": [
    {
      "name": "scrollable_renderer",
      "applyCondition": "${uiMode.hd}||${uiMode.fhd}",
      "type": "put_scrollable_renderer",
      "x": "(${width}-${scrollable_renderer.width})/2",
      "y": "(${height}-${scrollable_renderer.height})/2 + 31",
      "width": 456,
      "height": 222,
      "elements": {
        "text": {
          "type": "draw_multiline_string",
          "component": {
            "translate": "legacy.menu.how_to_play.multiplayer_message"
          },
          "width": 433
        },
        "hot-join": {
          "type": "draw_multiline_string",
          "component": {
            "translate": "legacy.menu.how_to_play.multiplayer_hot-join"
          },
          "width": 433,
          "applyCondition": "${loadedMods.hot-join}:false"
        },
        "world_host": {
          "type": "draw_multiline_string",
          "component": {
            "translate": "legacy.menu.how_to_play.multiplayer_world-host",
            "allowVariables": true,
            "args": [
              "controlIcon.legacy.key.host_options"
            ]
          },
          "width": 433,
          "applyCondition": "${loadedMods.world-host}:false"
        }
      }
    },
    {
      "name": "scrollable_renderer",
      "applyCondition": {
        "reference": "uiMode.sd"
      },
      "type": "put_scrollable_renderer",
      "x": "(${width}-${scrollable_renderer.width})/2",
      "y": "(${height}-${scrollable_renderer.height})/2 + 11",
      "contentX": 10,
      "contentY": 8,
      "width": 288,
      "height": 137,
      "lineHeight": 8,
      "elements": {
        "text": {
          "type": "draw_multiline_string",
          "component": {
            "translate": "legacy.menu.how_to_play.multiplayer_message",
            "font": "legacy:default_11"
          },
          "width": 268,
          "lineSpacing": 8
        },
        "hot-join": {
          "type": "draw_multiline_string",
          "component": {
            "translate": "legacy.menu.how_to_play.multiplayer_hot-join",
            "font": "legacy:default_11"
          },
          "width": 268,
          "lineSpacing": 8,
          "applyCondition": "${loadedMods.hot-join}:false"
        },
        "world_host": {
          "type": "draw_multiline_string",
          "component": {
            "translate": "legacy.menu.how_to_play.multiplayer_world-host",
            "font": "legacy:default_11",
            "allowVariables": true,
            "args": [
              "controlIcon.legacy.key.host_options"
            ]
          },
          "width": 268,
          "lineSpacing": 8,
          "applyCondition": "${loadedMods.world-host}:false"
        }
      }
    }
  ]
}