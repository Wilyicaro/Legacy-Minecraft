                "args": [
                  "controlIcon.key.use"
                ]
              },
              "width": 176
            },
            "text1": {
              "type": "draw_multiline_string",
              "component": {
                "translate": "legacy.menu.how_to_play.autocrafter_message_1"
              },
              "width": 176
            }
