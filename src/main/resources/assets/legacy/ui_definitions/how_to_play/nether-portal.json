{
  "elements": [
    {
      "name": "nether_portal_fhd_hd",
      "type": "children",
      "applyCondition": "${uiMode.hd}||${uiMode.fhd}",
      "applyPrefix": false,
      "elements": {
        "scrollable_renderer": {
          "type": "put_scrollable_renderer",
          "x": "${width}/2-228",
          "y": "(${height}-${scrollable_renderer.height})/2 + 31",
          "width": 200,
          "height": 222,
          "elements": {
            "text": {
              "type": "draw_multiline_string",
              "component": {
                "translate": "legacy.menu.how_to_play.nether-portal_message"
              },
              "width": 176
            },
            "text1": {
              "type": "draw_multiline_string",
              "component": {
                "translate": "legacy.menu.how_to_play.nether-portal_message_1"
              },
              "width": 176
            }
          }
        },
        "panel": {
          "type": "blit_sprite",
          "sprite": "legacy:tiles/small_panel",
          "width": 262,
          "height": 140,
          "x": "${width}/2-15",
          "y": "(${height}-${panel.height})/2+20"
        },
        "frame": {
          "type": "blit_sprite",
          "sprite": "legacy:tiles/square_recessed_panel",
          "width": "${panel.width}-14",
          "height": "${panel.height}-14",
          "x": "${panel.x}+7",
          "y": "${panel.y}+7"
        },
        "portal": {
          "type": "blit_sprite",
          "sprite": "legacy:container/how_to_play/nether-portal",
          "x": "${panel.x}+8",
          "y": "${panel.y}+8",
          "width": "${panel.width}-16",
          "height": "${panel.height}-16"
        }
      }
    },
    {
      "name": "nether_portal_sd",
      "type": "children",
      "applyCondition": {
        "reference": "uiMode.sd"
      },
      "applyPrefix": false,
      "elements": {
        "scrollable_renderer": {
          "type": "put_scrollable_renderer",
          "x": "${width}/2-144",
          "y": "(${height}-${scrollable_renderer.height})/2 + 11",
          "contentX": 10,
          "contentY": 8,
          "width": 140,
          "height": 137,
          "lineHeight": 8,
          "elements": {
            "text": {
              "type": "draw_multiline_string",
              "component": {
                "translate": "legacy.menu.how_to_play.nether-portal_message",
                "font": "legacy:default_11"
              },
              "width": 120,
              "lineSpacing": 8
            },
            "text1": {
              "type": "draw_multiline_string",
              "component": {
                "translate": "legacy.menu.how_to_play.nether-portal_message_1",
                "font": "legacy:default_11"
              },
              "width": 120,
              "lineSpacing": 8
            }
          }
        },
        "panel": {
          "type": "blit_sprite",
          "sprite": "legacy:tiles/panel",
          "width": 150,
          "height": 85,
          "x": "${width}/2",
          "y": "${scrollable_renderer.y}+(${scrollable_renderer.height}-${panel.height})/2"
        },
        "frame": {
          "type": "blit_sprite",
          "sprite": "legacy:tiles/square_recessed_panel",
          "width": "${panel.width}-10",
          "height": "${panel.height}-10",
          "x": "${panel.x}+5",
          "y": "${panel.y}+5"
        },
        "nether_portal": {
          "type": "blit_sprite",
          "sprite": "legacy:container/how_to_play/nether-portal",
          "x": "${frame.x}",
          "y": "${frame.y}",
          "translateX": 1.5,
          "translateY": 1.5,
          "width": "${frame.width}-3",
          "height": "${frame.height}-3"
        }
      }
    }
  ]
}