{
  "targetUI": "wily.legacy.client.screen.OptionsScreen",
  "targetType": "class",
  "applyCondition": {
    "reference": "uiMode.fhd"
  },
  "elements": {
    "panel.sprite": {
      "type": "put_resource_location",
      "value": "legacy:tiles/panel"
    },
    "tabList.sprites": {
      "type": "put_toggleable_tab_sprites",
      "value": {
        "high": {
          "left": "legacy:tiles/big_high_vert_tab_up",
          "middle": "legacy:tiles/big_high_vert_tab_middle",
          "right": "legacy:tiles/big_high_vert_tab_bottom"
        },
        "down": "legacy:tiles/big_low_vert_tab"
      }
    }
  }
}
