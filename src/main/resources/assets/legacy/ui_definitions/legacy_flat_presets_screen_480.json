    "renderableVList.presetMessage.xOffset": 18,
    "renderableVList.x": "${panel.x}+8",
    "renderableVList.y": "${panel.y}+18",
    "renderableVList.width": 146,
    "renderableVList.height": 117,
    "buttonsHeight": 15
  }
}