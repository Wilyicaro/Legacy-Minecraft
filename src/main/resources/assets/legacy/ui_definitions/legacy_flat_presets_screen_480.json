{
  "targetUI": "wily.legacy.client.screen.LegacyFlatPresetsScreen",
  "targetType": "class",
  "applyCondition": {
    "reference": "uiMode.sd"
  },
  "elements": {
    "panel.sprite": {
      "type": "put_resource_location",
      "value": "legacy:tiles/panel"
    },
    "panel.width": 164,
    "panel.height": 145,
    "panelRecess.x": "${panel.x}+4",
    "panelRecess.y": "${panel.y}+13",
