{
  "targetUI": "wily.legacy.client.screen.PlayGameScreen",
  "targetType": "class",
  "applyCondition": {
    "reference": "uiMode.sd"
  },
  "elements": {
    "panel.width": {
      "type": "put_number",
      "value": 201
    },
    "panel.y": {
      "type": "put_number",
      "value": "(${height}-${panel.height})/2"
    },
    "panel.height": {
      "type": "put_number",
      "value": 153
    },
    "buttonsHeight": {
      "type": "put_number",
      "value": 17
    },
    "loadingIcon.blockSize": {
      "type": "put_number",
      "value": 6
    },
    "loadingIcon.spacing": {
      "type": "put_number",
      "value": 3
    },
    "renderableVList.buttonIcon.width": {
      "type": "put_number",
      "value": 11
    },
    "renderableVList.buttonIcon.height": {
      "type": "put_number",
      "value": 11
    },
    "renderableVList.buttonMessage.xOffset": {
      "type": "put_number",
      "value": 22
    },
    "serverRenderableVList.buttonIcon.width": {
      "type": "put_number",
      "value": 11
    },
    "serverRenderableVList.buttonIcon.height": {
      "type": "put_number",
      "value": 11
    },
    "serverRenderableVList.buttonMessage.xOffset": {
      "type": "put_number",
      "value": 22
    },
    "serverRenderableVList.buttonMessage.right": {
      "type": "put_number",
      "value": 157
    },
    "serverRenderableVList.statusIcon.x": {
      "type": "put_number",
      "value": 159
    },
    "serverRenderableVList.statusIcon.y": {
      "type": "put_number",
      "value": 4
    },
    "serverRenderableVList.statusIcon.width": {
      "type": "put_number",
      "value": 8
    },
    "serverRenderableVList.statusIcon.height": {
      "type": "put_number",
      "value": 6
    },
    "serverRenderableVList.statusText.y": {
      "type": "put_number",
      "value": 4
    },
    "serverRenderableVList.statusText.right": {
      "type": "put_number",
      "value": 157
    },
    "serverRenderableVList.loadingIcon.blockSize": {
      "type": "put_number",
      "value": 3
    },
    "serverRenderableVList.loadingIcon.spacing": {
      "type": "put_number",
      "value": 1
    },
    "tabList.height": {
      "type": "put_number",
      "value": 21
    },
    "tabList.y": {
      "type": "put_number",
      "value": "${panel.y}-15"
    },
    "tabList.offset": {
      "type": "put_tab_state_offset",
      "value": {
        "unselected": [
          0,
          1.4
        ]
      }
    },
    "tabList.textYOffset": {
      "type": "put_number",
      "value": 0
    },
    "panelRecess.sprite": {
      "type": "put_resource_location",
      "value": "legacy:tiles/square_recessed_panel"
    },
    "panel.sprite": {
      "type": "put_resource_location",
      "value": "legacy:tiles/panel"
    },
    "tabList.sprites": {
      "type": "put_toggleable_tab_sprites",
      "value": {
        "high": {
          "left": "legacy:tiles/big_high_tab_left",
          "middle": "legacy:tiles/big_high_tab_middle",
          "right": "legacy:tiles/big_high_tab_right"
        },
        "down": "legacy:tiles/big_low_tab"
      }
    }
  }
}
