{
  "elements": {
    "changelogBackground": {
      "type": "blit_sprite",
      "sprite": "legacy:tiles/square_recessed_panel",
      "x": "${panel.x}+7",
      "y": "${panel.y}+10",
      "width": 353,
      "height": 190
    },
    "scrollable_renderer": {
      "type": "put_scrollable_renderer",
      "x": "${panel.x}-2",
      "y": "${panel.y}",
      "width": 370,
      "height": 200,
      "hasBackground": false,
      "lineHeight": 8,
      "elements": {
        "text": {
          "type": "draw_multiline_string",
          "component": {
            "translate": "legacy.menu.newerVersion",
            "font": "legacy:default_11"
          },
          "shadow": false,
          "color": "${commonColor.inventory_gray_text}",
          "lineHeight": 8,
          "width": 348
        },
        "text1": {
          "type": "draw_multiline_string",
          "component": {
            "reference": "legacy.changelog"
          },
          "shadow": false,
          "color": "${commonColor.inventory_gray_text}",
          "lineHeight": 8,
          "width": 348
        }
      }
    }
  }
}